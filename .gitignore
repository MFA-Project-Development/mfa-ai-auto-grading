# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
*.egg
*.egg-info/

# Root-anchored packaging output (avoid shadowing app/models, app/build, ...)
/build/
/dist/
/sdist/
/wheels/
/eggs/
/parts/
/var/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Environment variables / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# ---------------------------------------------------------------------------
# Logs & runtime artifacts
# ---------------------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Uploads / local file storage (STORAGE_DIR fallback)
# ---------------------------------------------------------------------------
/uploads/
/storage/

# ---------------------------------------------------------------------------
# Vector store (ChromaDB persistent dir — see settings.chroma_path)
# ---------------------------------------------------------------------------
/chroma_db/
*.sqlite
*.sqlite3
*.sqlite3-journal
*.db

# ---------------------------------------------------------------------------
# ML models & large binaries (root-anchored so app/models/ stays tracked)
# ---------------------------------------------------------------------------
/models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.ckpt

# Hugging Face / Torch caches
.cache/
.huggingface/

# ---------------------------------------------------------------------------
# Alembic (keep versions/, ignore only local SQL dumps if any)
# ---------------------------------------------------------------------------
*.sql.bak

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
compose.override.yml

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# Type checkers & linters
# ---------------------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
